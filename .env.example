# =============================================================================
# Variables d'environnement — Portfolio Kelyan AFONSO
# Copiez ce fichier en `.env.local` puis renseignez les valeurs.
# Aucune de ces variables n'est obligatoire pour que le site fonctionne.
# =============================================================================

# URL canonique du site en production (utilisée pour le SEO, l'OpenGraph,
# le sitemap.xml et le robots.txt). Sans slash final.
NEXT_PUBLIC_SITE_URL=https://kelyan-afonso.vercel.app

# --- Formulaire de contact (optionnel) -------------------------------------
# Le formulaire fonctionne sans backend (ouverture du client mail via mailto).
# Pour brancher un service externe (Formspree, Web3Forms, Resend...), ajoutez
# ici l'endpoint et décommentez l'appel correspondant dans
# components/sections/Contact.tsx.
# NEXT_PUBLIC_CONTACT_ENDPOINT=https://formspree.io/f/xxxxxxx
